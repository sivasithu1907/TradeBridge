# Copy this file to .env (same directory as docker-compose.yml) and fill
# in real values before running `docker compose up`.
# Generate strong random values with: openssl rand -hex 32

POSTGRES_PASSWORD=CHANGE_ME_GENERATE_A_RANDOM_VALUE
SESSION_SECRET=CHANGE_ME_GENERATE_A_64_CHAR_HEX_STRING

# CORS_ORIGINS: since nginx serves the frontend AND proxies /api on the
# same origin, the browser's fetch calls are same-origin and CORS doesn't
# actually come into play for normal use. Still set this to your server's
# address as a safety net. Use http://YOUR_SERVER_IP:8080 for now (no
# domain yet); switch to https://your-domain.com once you have one.
CORS_ORIGINS=http://YOUR_SERVER_IP:8080
