# --- Database ---
DATABASE_URL=postgres://tdv_app:CHANGE_ME@localhost:5432/tdv_marketplace

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Session ---
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# --- File storage ---
# Local disk for now. Swappable for S3-compatible storage later
# without changing route code (see src/services/storage.js).
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=15
